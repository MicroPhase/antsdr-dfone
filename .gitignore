# Generated distribution trees are ignored by default. Keep the
# checked-in Windows deliverables below.
host_app/DFONE/dist/
host_app/DFONE/user_gui/dist/

# Windows release build trees: ignore intermediates, keep final binaries.
host_app/DFONE/build-windows-release/
!host_app/DFONE/build-windows-release/
!host_app/DFONE/build-windows-release/apps-static/
!host_app/DFONE/build-windows-release/apps-static/Release/
!host_app/DFONE/build-windows-release/apps-static/Release/*.exe
!host_app/DFONE/build-windows-release/apps-static/dfone_host/
!host_app/DFONE/build-windows-release/apps-static/dfone_host/Release/
!host_app/DFONE/build-windows-release/apps-static/dfone_host/Release/*.lib
!host_app/DFONE/build-windows-release/sdk-shared/
!host_app/DFONE/build-windows-release/sdk-shared/Release/
!host_app/DFONE/build-windows-release/sdk-shared/Release/*.dll
!host_app/DFONE/build-windows-release/sdk-shared/Release/*.lib
!host_app/DFONE/build-windows-release/sdk-static/
!host_app/DFONE/build-windows-release/sdk-static/Release/
!host_app/DFONE/build-windows-release/sdk-static/Release/*.lib

host_app/DFONE/user_gui/build-win-single-exe/
!host_app/DFONE/user_gui/build-win-single-exe/
!host_app/DFONE/user_gui/build-win-single-exe/Release/
!host_app/DFONE/user_gui/build-win-single-exe/Release/*.exe
!host_app/DFONE/user_gui/build-win-single-exe/dfone_host/
!host_app/DFONE/user_gui/build-win-single-exe/dfone_host/Release/
!host_app/DFONE/user_gui/build-win-single-exe/dfone_host/Release/*.lib

# Packaged Windows deliverables kept in version control.
!host_app/DFONE/dist/
!host_app/DFONE/dist/windows/
!host_app/DFONE/dist/windows/*.zip
!host_app/DFONE/dist/windows/DFONE-Windows-SDK-*-x64/
!host_app/DFONE/dist/windows/DFONE-Windows-SDK-*-x64/apps/
!host_app/DFONE/dist/windows/DFONE-Windows-SDK-*-x64/apps/*.exe
!host_app/DFONE/dist/windows/DFONE-Windows-SDK-*-x64/sdk/
!host_app/DFONE/dist/windows/DFONE-Windows-SDK-*-x64/sdk/shared/
